{
  "rewrites": [
    { "source": "/madde/:kisim/:maddeNo", "destination": "/index.html" },
    { "source": "/sahis/:slug", "destination": "/index.html" },
    { "source": "/arama/:query*", "destination": "/index.html" },
    { "source": "/sozluk", "destination": "/index.html" },
    { "source": "/fevaid", "destination": "/index.html" },
    { "source": "/sahislar", "destination": "/index.html" },
    { "source": "/quiz", "destination": "/index.html" },
    { "source": "/hakkinda", "destination": "/index.html" },
    { "source": "/ayet-hadis", "destination": "/index.html" },
    { "source": "/okuma-plani", "destination": "/index.html" },
    { "source": "/gunun-bilgisi", "destination": "/index.html" },
    { "source": "/rehberler", "destination": "/index.html" },
    { "source": "/icerik", "destination": "/index.html" },
    { "source": "/arama", "destination": "/index.html" },
    { "source": "/fikih-karsilastirma", "destination": "/index.html" },
    { "source": "/calisma-alanim", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/(.*\\.js|.*\\.css)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
